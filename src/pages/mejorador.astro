---
import "../styles/global.css";
import background from "../assets/background.svg";
---
  <section style={`background-image: url(${background.src}); background-size: cover; background-position: center; background-repeat: no-repeat; min-height: 100vh;`}>
    <div class="preview flex gap-4">
      <!-- <div class="preview inline-block"> -->
      <input type="file" id="imageInput" />
      <div class="">
        <img id="show_input" width="400" height="400" />
      </div>
    </div>
    
    <!-- <br /> -->

    <!-- <div>
        <h1>botones de control:</h6>
        <select id="action">
          <option value="grayscale">Grayscale</option>
          <option value="edges">Edges</option>
          <option value="remove_bg">Remove Background</option>
        </select>
        <div class="range">
            <label for="threshold2">Umbral:</label>
            <input type="range" id="threshold2" min="0" max="255" value="200" />
        </div>
        
    </div> -->

    <!-- <br /> -->

    <div class="post_process">

      <button id="processBtn">Procesar</button>

      <div class="flex gap-4">
        <!-- <div style="display: flex; gap: 20px;"> -->
        <!-- <div class="inline-block"> -->
        <img id="result" width="400" height="400" />
      </div>
    </div>

  </section>

  <script>
    const btn = document.getElementById("processBtn");
    if (btn) btn.addEventListener("click", sendImage);

    const show_input = document.getElementById("show_input");
    const fileInput = document.getElementById("imageInput");
    if (fileInput instanceof HTMLInputElement && show_input instanceof HTMLImageElement) {
      fileInput.addEventListener("change", function () {
        const file = fileInput.files && fileInput.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function (e) {
            const result = e.target?.result;
            if (typeof result === "string") {
              show_input.src = result;
            } else {
              show_input.src = "";
            }
          };
          reader.readAsDataURL(file);
        } else {
          show_input.src = "";
        }
      });
    }

    async function sendImage() {
      const fileInput = document.getElementById("imageInput");
      const actionSelect = document.getElementById("action");
      if (!(fileInput instanceof HTMLInputElement) || !(actionSelect instanceof HTMLSelectElement)) {
        alert("Por favor, selecciona una imagen y una acción.");
        return;
      }
      const action_do = actionSelect.value;
      if (!fileInput.files?.[0]) {
        alert("Por favor, selecciona una imagen.");
        return;
      }
      if (!action_do) {
        alert("Por favor, selecciona una acción.");
        return;
      }

      const formData = new FormData();
      formData.append("image", fileInput.files[0]);
      formData.append("action", action_do);

      const res = await fetch("http://127.0.0.1:5000/process", {
        method: "POST",
        body: formData,
      });

      const blob = await res.blob();
      const resultImage = document.getElementById("result");
      if (resultImage instanceof HTMLImageElement) {
        resultImage.src = URL.createObjectURL(blob);
      }
    }
  </script>